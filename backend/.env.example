# AI 服务配置（默认：通义千问 Qwen-VL-Plus）
# 注册获取 API Key: https://bailian.console.aliyun.com
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-vl-plus

# 备用方案：DeepSeek（仅文本，不支持视觉）
# AI_API_KEY=sk-your_deepseek_key
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# 备用方案：智谱 GLM-4V
# AI_API_KEY=your_glm_key
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4v

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 图像压缩配置
MAX_IMAGE_WIDTH=640
MAX_IMAGE_HEIGHT=480
JPEG_QUALITY=60
